# Application
NODE_ENV=development
PORT=3000
APP_NAME=Nexly Event Processor

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=root
DB_NAME=events_db
DB_SYNC=true

# Redis (Idempotência e Cache)
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka (Mensageria Assíncrona)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=event-processor-api
KAFKA_GROUP_ID=event-processor-group

# External Integrations (Mock)
MOCK_INTEGRATIONS_URL=http://localhost:4000

# Logging
LOG_LEVEL=debug